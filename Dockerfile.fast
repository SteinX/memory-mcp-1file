# Recommended: run with --memory 4g
# Minimum: 2g for small codebases (<1K files), 4g for medium (1-10K files)
FROM debian:testing-slim

# Install minimal runtime deps
# We need CA certificates for HTTPS requests (e.g. to OpenAI/SurrealDB)
RUN apt-get update && apt-get install -y \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy the GNU binary built locally (fast profile)
# Ensure you ran `cargo build --profile fast` first
COPY target/fast/memory-mcp /usr/local/bin/memory-mcp

# Data directory setup
RUN mkdir -p /data /project
ENV DATA_DIR=/data
ENV LOG_LEVEL=info
# SurrealKV WAL recovery needs extra stack. 8MB is sufficient since
# HNSW indexes use IF NOT EXISTS (no O(n log n) rebuild on startup).
ENV RUST_MIN_STACK=16777216
# Limit glibc malloc arenas to reduce memory fragmentation in containers.
# Without this, glibc can create up to 8×CPU arenas, wasting hundreds of MB.
ENV MALLOC_ARENA_MAX=2
# Let candle/rayon use all available cores for GEMM during inference
ENV RAYON_NUM_THREADS=0
# SurrealKV auto-sets block cache to (total_memory/2 - 1GB) which is 2GB at --memory 6g.
# Cap at 256MB to leave room for embedding model (1.2GB) + HNSW indexes + BM25.
ENV SURREAL_SURREALKV_BLOCK_CACHE_CAPACITY=268435456

# Persist data and allow project mounting
VOLUME ["/data", "/project"]

CMD ["memory-mcp", "--data-dir", "/data"]
