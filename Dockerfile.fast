# Recommended: run with --memory 6g for production workloads
# Minimum: 3g for small codebases, 6g for large (50K+ chunks)
FROM debian:testing-slim

# Install minimal runtime deps
# We need CA certificates for HTTPS requests (e.g. to OpenAI/SurrealDB)
RUN apt-get update && apt-get install -y \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy the GNU binary built locally (fast profile)
# Ensure you ran `cargo build --profile fast` first
COPY target/fast/memory-mcp /usr/local/bin/memory-mcp

# Data directory setup
RUN mkdir -p /data /project
ENV DATA_DIR=/data
ENV LOG_LEVEL=info
# SurrealKV WAL recovery uses deep recursion on large datasets;
# 16 MB prevents stack overflow in spawn_blocking threads.
ENV RUST_MIN_STACK=16777216
# Limit glibc malloc arenas to reduce memory fragmentation in containers.
# Without this, glibc can create up to 8×CPU arenas, wasting hundreds of MB.
ENV MALLOC_ARENA_MAX=2

# Persist data and allow project mounting
VOLUME ["/data", "/project"]

CMD ["memory-mcp", "--data-dir", "/data"]
