# ==========================================
# Memory MCP Configuration Template
# ==========================================

# Directory where SurrealDB data will be stored
DATA_DIR=./data

# Directory for downloaded HuggingFace model files.
# Leave unset for native runs to share one durable platform app-data location across data dirs.
# Existing model files under DATA_DIR/models are reused for backward compatibility.
# Docker images set this to /data/models so the model stays inside the data volume.
# EMBEDDING_MODEL_CACHE_DIR=/path/to/shared/models

# Model selection. Gemma is the default.
# Options: qwen3, gemma, bge_m3, nomic, e5_multi, e5_small
EMBEDDING_MODEL=gemma

# Matryoshka Representation Learning (MRL) dimension.
# Leave commented out to use the model's native maximum dimension (e.g. 1024 for Qwen3).
# MRL_DIM=512

# Hugging Face Access Token
# Optional; useful for higher rate limits or private/rate-limited models.
# HF_TOKEN=hf_your_token_here

# Inference settings
BATCH_SIZE=8
CACHE_SIZE=1000

# Logging verbosity (trace, debug, info, warn, error)
LOG_LEVEL=info
