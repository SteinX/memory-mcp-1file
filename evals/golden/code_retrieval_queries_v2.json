    "medium": {
      "target_minutes": "15-30",
      "required_by_default": false,
      "optional_policy": "explicit medium validation run"
    },
    "stress": {
      "target_minutes": "45-90+",
      "required_by_default": false,
      "optional_policy": "manual-only stress execution"
    }
